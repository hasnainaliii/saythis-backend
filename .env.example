# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Used by the `postgres` service in docker-compose.
POSTGRES_USER=saythis
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=saythis

# Full connection string consumed by both the `migrate` and `app` services.
# If PostgreSQL runs inside Docker Compose, use the service name as the host.
DATABASE_URL=postgres://saythis:change_me_strong_password@postgres:5432/saythis?sslmode=disable

# ── Application ─────────────────────────────────────────────────────────────
PORT=:8080
APP_ENV=production

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_64_char_hex_secret

# ── External services ───────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FRONTEND_URL=https://your-frontend-domain.com
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Docker port mapping (host port → container port 8080) ───────────────────
HOST_PORT=8080
