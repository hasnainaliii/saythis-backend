.env.*
*.pem
*.key
*.crt

# ── Documentation ──────────────────────────────────────────────────────────
docs/
*.md
README*
LICENCE*
LICENSE*

# ── Tests ──────────────────────────────────────────────────────────────────
testdata/
*_test.go

# ── IDE / editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
